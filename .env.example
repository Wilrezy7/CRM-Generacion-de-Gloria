PORT=4000
NODE_ENV=development
JWT_SECRET=replace-with-a-long-random-secret
JWT_ACCESS_MINUTES=60
REFRESH_TOKEN_DAYS=30
PASSWORD_RESET_MINUTES=30
EMAIL_VERIFICATION_MINUTES=120
APP_BASE_URL=http://localhost:4000
CORS_ORIGIN=http://localhost:4000
EMAIL_DELIVERY_MODE=log
EMAIL_WEBHOOK_URL=
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=40

# Required to use Supabase as the storage driver
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxx

# Recommended for backend writes. Prefer this over publishable keys.
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxx

# Optional legacy aggregate storage table. Keep crm_state until normalized table migration is complete.
SUPABASE_TABLE=crm_state
SUPABASE_RECORD_ID=generacion-de-gloria
SUPABASE_ENFORCE_REMOTE=true

# Only for temporary local testing. Not recommended in production.
SUPABASE_ALLOW_INSECURE_PUBLISHABLE_WRITE=false
